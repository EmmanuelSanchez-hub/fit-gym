# =============================================================================
# FitGym Pro - Variables de Entorno
# =============================================================================
# Copia este archivo como .env y completa los valores
# cp .env.example .env
# =============================================================================

# =============================================================================
# BASE DE DATOS (SQLite)
# =============================================================================
# Ruta del archivo de base de datos SQLite
DATABASE_URL="file:./db/custom.db"

# =============================================================================
# NEXT-AUTH (Autenticación)
# =============================================================================
# URL base de la aplicación (producción: https://cabfi.qzz.io)
NEXTAUTH_URL="https://cabfi.qzz.io"

# Secreto para firmar tokens JWT de NextAuth
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-super-seguro-aqui-cambialo"

# =============================================================================
# SERVICIOS INTERNOS
# =============================================================================
# URL del servicio de WhatsApp (interno, no expuesto públicamente)
WHATSAPP_SERVICE_URL="http://localhost:3004"

# URL del servicio de huella digital (interno, no expuesto públicamente)
FINGERPRINT_SERVICE_URL="http://localhost:3005"

# =============================================================================
# MODO DE EJECUCIÓN
# =============================================================================
# development | production | test
NODE_ENV=development

# =============================================================================
# PUERTOS (Opcional - valores por defecto)
# =============================================================================
# Puerto para la aplicación Next.js
PORT=3000

# =============================================================================
# SEGURIDAD (Opcional)
# =============================================================================
# Tasa límite de requests por minuto (producción)
# RATE_LIMIT_REQUESTS=100

# Tiempo de expiración de sesión en horas (por defecto: 24)
# SESSION_EXPIRY_HOURS=24